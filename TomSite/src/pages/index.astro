---
import Layout from '../layouts/Layout.astro';
import Outside from '../components/Outside.astro';

const tiles = [
  {
    href: '/coffee',
    title: 'Coffee',
    tag: 'brew log',
    blurb: 'Current beans, gear shelf, and whatever is dripping right now.',
    span: 'md:col-span-2',
  },
  {
    href: '/pokemon',
    title: 'Pokémon TCG',
    tag: 'collection',
    blurb: 'The collection, filterable by set and grade.',
    span: '',
  },
  {
    href: '/photos',
    title: 'Photos',
    tag: 'galleries',
    blurb: 'Trip and theme galleries.',
    span: '',
  },
  {
    href: '/retreats',
    title: 'Retreats',
    tag: 'trips',
    blurb: 'Outdoor trips I organize, with a map.',
    span: 'md:col-span-2',
  },
  {
    href: '/art',
    title: 'Art',
    tag: 'creative',
    blurb: 'Latte art, hand-drawn sketches, and AI-art experiments.',
    span: '',
  },
  {
    href: '/now',
    title: 'Now',
    tag: 'live',
    blurb: 'Status, updated often.',
    span: '',
  },
  {
    href: '/about',
    title: 'About',
    tag: 'the human stuff',
    blurb: 'What I do, who I am.',
    span: '',
  },
  {
    href: '/game',
    title: 'Moon Lander',
    tag: 'play',
    blurb: 'A roguelite lander game — 10 levels, procedural upgrades. Land gently.',
    span: 'md:col-span-2',
  },
];
---

<Layout>
  <section class="mb-10 relative overflow-hidden">
    <div class="ambient-blob" data-parallax="0.15" aria-hidden="true"></div>

    <!-- Autonomous orbiting accents — always drifting, independent of scroll/cursor -->
    <div class="orbit-field" aria-hidden="true">
      <div class="orbit-ring" style="animation-duration: 18s; left: 8%; top: 30%;">
        <div class="orbit-dot" style="width:6px; height:6px; background:var(--color-accent); left:70px; top:0; animation-duration: 18s;"></div>
      </div>
      <div class="orbit-ring" style="animation-duration: 26s; animation-direction: reverse; left: 85%; top: 60%;">
        <div class="orbit-dot" style="width:4px; height:4px; background:var(--color-accent-2); left:46px; top:0; animation-duration: 26s; animation-direction: reverse;"></div>
      </div>
      <div class="orbit-ring" style="animation-duration: 32s; left: 50%; top: 10%;">
        <div class="orbit-dot" style="width:3px; height:3px; background:var(--color-signal); left:110px; top:0; animation-duration: 32s;"></div>
      </div>
    </div>

    <div class="relative">
      <h1 class="font-display text-4xl md:text-6xl font-semibold tracking-tight overflow-hidden py-1" data-scroll-fx>
        <span class="kinetic-word" style="--i:0">Hey,</span>
        <span class="kinetic-word" style="--i:1">I'm</span>
        <span class="kinetic-word gradient-text flicker-hover" style="--i:2">Tom</span><span class="kinetic-word" style="--i:3">.</span>
      </h1>
      <p class="mt-4 max-w-xl text-muted text-lg" data-kinetic>
        Welcome in. Coffee's usually on, there's always a collection growing in the corner, and I'm probably planning the next trip into the woods.
      </p>
    </div>
  </section>

  <!-- Outside widget lives OUTSIDE the bento grid on purpose: its content
       height varies (location button, wrapping status text, geolocation
       state) and a fixed auto-rows track caused it to be overlapped by the
       next row. Keeping it as its own full-width block avoids that whole
       class of bug regardless of how tall its content gets. -->
  <div class="mb-4">
    <Outside />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[180px]">
    {tiles.map((tile, i) => (
      <a
        href={tile.href}
        class={`tile reveal flex flex-col justify-between ${tile.span}`}
        style={`transition-delay: ${Math.min(i * 60, 300)}ms`}
      >
        <span class="badge">{tile.tag}</span>
        <div>
          <h2 class="font-display text-xl font-semibold">{tile.title}</h2>
          <p class="mt-1 text-sm text-muted">{tile.blurb}</p>
        </div>
      </a>
    ))}
  </div>
</Layout>

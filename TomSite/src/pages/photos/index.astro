---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const galleries = await getCollection('photos');
---

<Layout title="Photos — Tomfoolery" description="Trip and theme galleries.">
  <span class="badge">galleries</span>
  <h1 class="font-display text-3xl md:text-4xl font-semibold mt-2">Photos</h1>
  <p class="text-muted mt-2 max-w-xl">Trip and theme galleries.</p>

  <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    {galleries.map((gallery) => (
      <article class="tile reveal aspect-square flex flex-col justify-end">
        <h2 class="font-display font-semibold">{gallery.data.title}</h2>
        {gallery.data.location && <p class="text-sm text-muted">{gallery.data.location}</p>}
      </article>
    ))}
  </div>
</Layout>

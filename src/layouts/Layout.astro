---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tomfoolery",
  description = "Tom's personal hub — photos, collections, coffee, and whatever else.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-canvas text-ink font-body antialiased">
    <header class="glass-nav">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="font-display font-semibold tracking-tight text-lg flicker-hover">
          Tom<span class="gradient-text">foolery</span>
        </a>
        <nav class="flex items-center gap-5 text-sm text-muted font-mono">
          <a href="/now" class="hover:text-ink transition-colors">now</a>
          <a href="/about" class="hover:text-ink transition-colors">about</a>
        </nav>
      </div>
    </header>
    <main class="max-w-6xl mx-auto px-6 py-10 relative z-10" transition:name="main-content" transition:animate="fade">
      <slot />
    </main>
    <footer class="max-w-6xl mx-auto px-6 py-12 text-xs text-muted font-mono relative z-10">
      built with a little help from an AI, tended by hand
    </footer>

    <script>
      // --- Scroll reveal (tiles/sections) ---
      function setupReveal() {
        const els = document.querySelectorAll('.reveal:not(.is-visible)');
        if (!('IntersectionObserver' in window) || els.length === 0) {
          document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      }

      // --- Kinetic type: split [data-kinetic] elements into word spans ---
      function setupKineticType() {
        document.querySelectorAll('[data-kinetic]:not([data-kinetic-done])').forEach((el) => {
          const text = el.textContent ?? '';
          const words = text.split(/(\s+)/);
          el.innerHTML = words
            .map((w, i) =>
              w.trim() === ''
                ? w
                : `<span class="kinetic-word" style="--i:${i}">${w}</span>`
            )
            .join('');
          el.setAttribute('data-kinetic-done', 'true');
        });

        const kineticEls = document.querySelectorAll('.kinetic-word:not(.is-visible)');
        if (!('IntersectionObserver' in window)) {
          kineticEls.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        kineticEls.forEach((el) => io.observe(el));
      }

      function initAll() {
        setupReveal();
        setupKineticType();
      }

      document.addEventListener('astro:page-load', initAll);
    </script>
  </body>
</html>

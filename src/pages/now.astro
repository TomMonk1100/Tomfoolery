---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Edit this list whenever something changes — ask Claude to update it,
// use the /admin portal, or edit directly once you're comfortable.
const nowItems = [
  { label: 'brewing', value: 'placeholder — current beans go here' },
  { label: 'collecting', value: 'placeholder — latest Pokémon/figure pull' },
  { label: 'driving', value: 'IONIQ 5' },
  { label: 'watching', value: 'placeholder' },
];

const lastUpdated = 'June 30, 2026';

const posts = (await getCollection('now')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function fmt(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
}
---

<Layout title="Now — Tomfoolery" description="What Tom is into right now — a running log of coffee, retreats, and whatever else.">
  <div class="max-w-2xl reveal is-visible">
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-signal live-pulse"></span>
      <span class="badge badge-signal">live</span>
    </div>
    <h1 class="font-display text-3xl md:text-4xl font-semibold mt-2">
      Right now
    </h1>
    <p class="text-muted text-sm font-mono mt-1">last updated {lastUpdated}</p>
    <p class="text-muted text-sm mt-3">
      Looking for weather, sunset, moon phase, and the ISS? That live widget
      lives on the <a href="/" class="gradient-text font-medium">home page</a> now.
    </p>
  </div>

  <ul class="mt-6 max-w-2xl space-y-3">
    {nowItems.map((item, i) => (
      <li class="tile reveal flex flex-col sm:flex-row sm:items-baseline sm:gap-4" style={`transition-delay: ${i * 60}ms`}>
        <span class="badge shrink-0 w-28">{item.label}</span>
        <span class="text-ink">{item.value}</span>
      </li>
    ))}
  </ul>

  <div class="mt-12 max-w-2xl">
    <h2 class="font-display text-xl font-semibold">The log</h2>
    <p class="text-muted text-sm mt-1">Coffee, retreats, life — whatever's current, roughly in order.</p>

    <div class="mt-6 space-y-4">
      {posts.map((post, i) => (
        <a href={`/now/${post.id}`} class="tile reveal flex gap-4 items-start" style={`transition-delay: ${Math.min(i * 60, 300)}ms`}>
          {post.data.image && (
            <img src={post.data.image} alt={post.data.title} class="w-20 h-20 object-cover rounded-sm border border-line shrink-0" loading="lazy" />
          )}
          <div>
            <p class="flex flex-wrap items-center gap-2 text-xs font-mono text-muted">
              <span>{fmt(post.data.date)}</span>
              {post.data.tag && <span class="badge">{post.data.tag}</span>}
              {post.data.location && <span>{post.data.location}</span>}
            </p>
            <h3 class="font-display font-semibold mt-1">{post.data.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

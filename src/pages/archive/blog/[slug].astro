---
// Individual past-blog post — /archive/blog/:slug
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('pastBlog');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

function fmt(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
}
---

<Layout title={`${entry.data.title} — Tom of the Past`} description={entry.data.title}>
  <a href="/archive" class="badge hover:text-ink transition-colors">← the vault</a>
  <h1 class="font-display text-3xl md:text-4xl font-semibold mt-3 max-w-2xl">{entry.data.title}</h1>
  <p class="mt-2 font-mono text-sm text-muted">{fmt(entry.data.date)} · from the old blog, lightly tidied</p>

  <div class="past-prose mt-8 max-w-xl leading-relaxed [&_p]:mt-4 [&_p:first-child]:mt-0">
    <Content />
  </div>
</Layout>

<style>
  .past-prose {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.05rem;
  }
</style>

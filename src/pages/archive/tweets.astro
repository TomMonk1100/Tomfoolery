---
// "On This Day" tweet archive — /archive/tweets. Shows every tweet posted on
// today's calendar date across 2008–2018, grouped by year, with prev/next day
// navigation and a search box across the full archive. Data is month-chunked
// JSON in /public/archive/. Supports ?date=MM-DD#tID deep links.
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Old Tweets — Tom of the Past" description="13,686 tweets from 2008–2018, served one day at a time.">
  <a href="/archive" class="badge hover:text-ink transition-colors">← the vault</a>
  <h1 class="font-display text-3xl md:text-4xl font-semibold mt-3">On This Day</h1>
  <p class="mt-2 text-muted max-w-xl">
    13,686 original tweets, 2008–2018 — served one calendar day at a time.
  </p>

  <!-- Day navigation -->
  <div class="mt-6 flex items-center gap-3">
    <button id="prev-day" class="day-nav" aria-label="previous day">← prev</button>
    <div class="text-center min-w-[12rem]">
      <div id="day-label" class="font-display text-2xl font-semibold">&nbsp;</div>
      <div id="day-count" class="font-mono text-xs text-muted">&nbsp;</div>
    </div>
    <button id="next-day" class="day-nav" aria-label="next day">next →</button>
    <button id="today-btn" class="day-nav hidden" title="back to today">today</button>
  </div>

  <ol id="tweet-list" class="mt-6 space-y-6 max-w-xl"></ol>

  <!-- Search -->
  <div class="mt-12 max-w-xl border-t border-dotted border-line pt-6">
    <label for="tweet-search" class="font-mono text-xs text-muted uppercase tracking-wider">Or search all ten years</label>
    <input
      id="tweet-search"
      type="search"
      placeholder="search every tweet…"
      autocomplete="off"
      class="mt-2 w-full bg-surface border border-line px-3 py-2 font-mono text-sm focus:outline-none focus:border-accent"
    />
    <div id="search-status" class="mt-2 font-mono text-xs text-muted"></div>
    <ol id="search-results" class="mt-4 space-y-4"></ol>
  </div>

  <script>
    const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const monthCache = {};
    let cur = { m: 0, d: 0 }; // 1-based month/day currently shown

    function esc(s) {
      return s.replace(/[&<>"']/g, (c) => '&#' + c.charCodeAt(0) + ';');
    }

    function linkify(text, urls) {
      let i = 0;
      return esc(text).replace(/https?:\/\/t\.co\/\w+/g, (m) => {
        const target = urls && urls[i] ? urls[i] : m;
        i++;
        const label = target.replace(/^https?:\/\/(www\.)?/, '').slice(0, 40);
        return '<a href="' + esc(target) + '" class="text-accent underline decoration-dotted" rel="nofollow noopener">' + esc(label) + '</a>';
      });
    }

    async function getMonth(m) {
      const key = String(m).padStart(2, '0');
      if (!monthCache[key]) {
        const res = await fetch('/archive/tweets-m' + key + '.json');
        monthCache[key] = res.ok ? await res.json() : [];
      }
      return monthCache[key];
    }

    function tweetCard(t, withYear) {
      const time = t.ts.slice(11, 16);
      const date = withYear ? t.ts.slice(0, 10) + ' · ' : '';
      return '<li id="t' + t.id + '" class="tweet-card">' +
        '<p class="text-[0.95rem] leading-relaxed">' + linkify(t.text, t.urls) + '</p>' +
        '<p class="mt-1 font-mono text-xs text-muted">' + date + time + '</p></li>';
    }

    function shiftDay(m, d, delta) {
      // navigate calendar month-days; year 2012 chosen as leap so Feb 29 exists
      const dt = new Date(Date.UTC(2012, m - 1, d));
      dt.setUTCDate(dt.getUTCDate() + delta);
      return { m: dt.getUTCMonth() + 1, d: dt.getUTCDate() };
    }

    async function showDay(m, d, anchor) {
      cur = { m, d };
      const label = document.getElementById('day-label');
      const countEl = document.getElementById('day-count');
      const list = document.getElementById('tweet-list');
      label.textContent = MONTH_NAMES[m - 1] + ' ' + d;
      countEl.textContent = 'loading…';
      list.innerHTML = '';

      const now = new Date();
      document.getElementById('today-btn').classList.toggle(
        'hidden', m === now.getMonth() + 1 && d === now.getDate()
      );
      const url = new URL(location.href);
      url.searchParams.set('date', String(m).padStart(2, '0') + '-' + String(d).padStart(2, '0'));
      history.replaceState(null, '', url.pathname + url.search + (anchor ? '#' + anchor : ''));

      const mmdd = '-' + String(m).padStart(2, '0') + '-' + String(d).padStart(2, '0');
      const hits = (await getMonth(m)).filter((t) => t.ts.slice(4, 10) === mmdd);

      if (hits.length === 0) {
        countEl.textContent = 'no tweets on this day';
        list.innerHTML = '<li class="text-muted text-sm font-mono">past Tom was quiet on ' +
          MONTH_NAMES[m - 1] + ' ' + d + '. try the arrows.</li>';
        return;
      }
      countEl.textContent = hits.length + ' tweet' + (hits.length === 1 ? '' : 's') + ' across the years';

      const byYear = {};
      hits.forEach((t) => (byYear[t.ts.slice(0, 4)] = byYear[t.ts.slice(0, 4)] || []).push(t));
      list.innerHTML = Object.keys(byYear).sort().reverse().map((y) =>
        '<li><h2 class="font-display text-lg font-semibold border-b border-dotted border-line pb-1">' +
        MONTH_NAMES[m - 1] + ' ' + d + ', ' + y +
        '</h2><ol class="mt-3 space-y-3">' +
        byYear[y].map((t) => tweetCard(t, false)).join('') +
        '</ol></li>'
      ).join('');

      if (anchor) {
        const el = document.getElementById(anchor);
        if (el) { el.scrollIntoView({ block: 'center' }); el.classList.add('tweet-hit'); }
      }
    }

    async function searchAll(q) {
      const status = document.getElementById('search-status');
      const out = document.getElementById('search-results');
      out.innerHTML = '';
      if (q.length < 2) { status.textContent = ''; return; }
      status.textContent = 'digging through ten years…';
      const months = await Promise.all(Array.from({ length: 12 }, (_, i) => getMonth(i + 1)));
      const hits = months.flat().filter((t) => t.text.toLowerCase().includes(q)).sort((a, b) => a.ts < b.ts ? -1 : 1);
      status.textContent = hits.length + ' tweet' + (hits.length === 1 ? '' : 's') + ' match' +
        (hits.length === 1 ? 'es' : '') + (hits.length > 100 ? ' (showing first 100)' : '');
      out.innerHTML = hits.slice(0, 100).map((t) => tweetCard(t, true)).join('');
      // clicking a search result's date jumps the day view to that date
      out.querySelectorAll('.tweet-card').forEach((el, i) => {
        const t = hits[i];
        el.addEventListener('click', () => {
          showDay(parseInt(t.ts.slice(5, 7), 10), parseInt(t.ts.slice(8, 10), 10), 't' + t.id);
          window.scrollTo({ top: 0 });
        });
        el.classList.add('cursor-pointer');
      });
    }

    function init() {
      const prev = document.getElementById('prev-day');
      if (!prev || prev.dataset.ready) return;
      prev.dataset.ready = 'true';

      prev.addEventListener('click', () => { const n = shiftDay(cur.m, cur.d, -1); showDay(n.m, n.d); });
      document.getElementById('next-day').addEventListener('click', () => { const n = shiftDay(cur.m, cur.d, 1); showDay(n.m, n.d); });
      document.getElementById('today-btn').addEventListener('click', () => {
        const now = new Date(); showDay(now.getMonth() + 1, now.getDate());
      });

      let timer;
      document.getElementById('tweet-search').addEventListener('input', (e) => {
        clearTimeout(timer);
        timer = setTimeout(() => searchAll(e.target.value.trim().toLowerCase()), 250);
      });

      const params = new URLSearchParams(location.search);
      const dateParam = params.get('date');
      const anchor = location.hash ? location.hash.slice(1) : undefined;
      if (dateParam && /^\d{2}-\d{2}$/.test(dateParam)) {
        showDay(parseInt(dateParam.slice(0, 2), 10), parseInt(dateParam.slice(3), 10), anchor);
      } else {
        const now = new Date();
        showDay(now.getMonth() + 1, now.getDate(), anchor);
      }
    }

    document.addEventListener('astro:page-load', init);
    init();
  </script>

  <style>
    .day-nav {
      border: 1px solid var(--color-line);
      background: var(--color-surface);
      padding: 0.35rem 0.9rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      cursor: pointer;
      box-shadow: 2px 2px 0 var(--color-surface-2);
      transition: all 0.15s;
    }
    .day-nav:hover { border-color: var(--color-accent); color: var(--color-accent); }
    .day-nav:active { box-shadow: none; transform: translate(2px, 2px); }
    .tweet-card {
      border: 1px solid var(--color-line);
      background: var(--color-surface);
      padding: 0.85rem 1rem;
      box-shadow: 3px 3px 0 var(--color-surface-2);
    }
    .tweet-hit {
      border-color: var(--color-accent);
      box-shadow: 3px 3px 0 var(--color-accent);
    }
  </style>
</Layout>

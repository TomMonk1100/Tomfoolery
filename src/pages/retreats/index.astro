---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const retreats = (await getCollection('retreats')).sort(
  (a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0)
);
---

<Layout title="Retreats — Tomfoolery" description="Outdoor trips I organize, with a map.">
  <span class="badge">trips</span>
  <h1 class="font-display text-3xl md:text-4xl font-semibold mt-2">Retreats</h1>
  <p class="text-muted mt-2 max-w-xl">
    Outdoor trips I plan for friends and family. An interactive map with pins
    per trip is a fast-follow — trip pages ship first.
  </p>

  <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
    {retreats.map((trip) => (
      <a href={`/retreats/${trip.id}`} class="tile reveal">
        <span class="badge">{trip.data.status}</span>
        <h2 class="font-display text-lg font-semibold mt-2">{trip.data.title}</h2>
        {trip.data.location && <p class="text-sm text-muted mt-1">{trip.data.location}</p>}
      </a>
    ))}
  </div>
</Layout>

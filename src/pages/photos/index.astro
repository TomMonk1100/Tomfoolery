---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const galleries = await getCollection('photos');
---

<Layout title="Photos — Tomfoolery" description="Trip and theme galleries.">
  <span class="badge">galleries</span>
  <h1 class="font-display text-3xl md:text-4xl font-semibold mt-2">Photos</h1>
  <p class="text-muted mt-2 max-w-xl">Trip and theme galleries.</p>

  <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    {galleries.map((gallery) => (
      <a href={`/photos/${gallery.id}`} class="tile reveal aspect-square flex flex-col justify-end !p-0 overflow-hidden relative">
        {gallery.data.image && (
          <img src={gallery.data.image} alt={gallery.data.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
        )}
        <div class="relative z-10 p-4" style="background:linear-gradient(to top, rgba(23,16,9,0.85), transparent 90%);">
          <h2 class="font-display font-semibold" style={gallery.data.image ? 'color:#F4EBDA' : ''}>{gallery.data.title}</h2>
          {gallery.data.location && <p class="text-sm" style={gallery.data.image ? 'color:#B9A480' : ''}>{gallery.data.location}</p>}
        </div>
      </a>
    ))}
  </div>
</Layout>

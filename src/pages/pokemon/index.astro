---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('pokemon');
---

<Layout title="Pokémon TCG — Tomfoolery" description="The collection, filterable by set and grade.">
  <span class="badge">collection</span>
  <h1 class="font-display text-3xl md:text-4xl font-semibold mt-2">Pokémon TCG</h1>
  <p class="text-muted mt-2 max-w-xl">
    Set/grade filtering is a fast-follow — for now, the full collection.
  </p>

  <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
    {entries.map((entry) => (
      <a href={`/pokemon/${entry.id}`} class="tile reveal">
        {entry.data.image && (
          <img src={entry.data.image} alt={entry.data.title} class="w-full aspect-square object-cover rounded-sm mb-3 border border-line" loading="lazy" />
        )}
        <h2 class="font-display font-semibold">{entry.data.title}</h2>
        {entry.data.set && <p class="text-sm text-muted mt-1">{entry.data.set}</p>}
        {entry.data.grade && <p class="badge mt-2">{entry.data.grade}</p>}
      </a>
    ))}
  </div>
</Layout>

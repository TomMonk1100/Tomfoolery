---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Moon Lander — Tomfoolery" description="An endless roguelite Moon Lander — procedurally harder levels, upgrades with real tradeoffs.">
  <div class="reveal is-visible">
    <!-- On phones the canvas must be the first thing under the nav — no
         scrolling to reach the action (the in-canvas title screen already
         introduces the game). The header lives here for sm+ viewports and
         moves into a collapsible section below the game on mobile. -->
    <div class="hidden sm:block">
      <span class="badge">play</span>
      <h1 class="font-display text-3xl md:text-4xl font-semibold mt-2">Moon Lander</h1>
      <p class="text-muted mt-2 text-sm">
        Land gently on the pad. Endless levels, each harder than the last — pick an
        upgrade after every landing, but every boon has a cost. Three difficulty
        modes. Built with canvas + Web Audio, no libraries.
      </p>
    </div>

    <div id="lander-root" class="mt-0 sm:mt-6 relative">
      <div class="game-bleed">
        <div class="tile !p-0 overflow-hidden relative">
          <canvas class="block w-full"></canvas>

          <!-- HUD — fuel folded into the top row as a compact chip instead
               of a separate row. Terrain groundBase sits ~72% down the
               canvas (levels.ts), so a bottom-anchored fuel bar could end up
               sitting right on top of the landing pad depending on level
               layout (confirmed bug: pad hidden behind the fuel bar on a
               hills level) — the top is reliably clear of terrain across
               every terrain type. Kept it in the SAME row (not a new one
               below) rather than growing the HUD's height, since the ship
               now spawns much closer to the top (main.ts) and a taller HUD
               block would just reintroduce the same "hidden behind the HUD"
               problem for the ship instead of the pad. flex-wrap already
               handles overflow on the narrowest phones exactly like the
               other chips. -->
          <div class="absolute top-2 left-2 right-2 sm:top-3 sm:left-3 sm:right-3 flex items-start justify-between gap-2 font-mono text-xs pointer-events-none">
            <div class="flex items-center gap-1.5 sm:gap-2 pointer-events-auto flex-wrap">
              <div class="bg-canvas/70 px-2 py-1 border border-line">
                <span class="text-muted">LVL </span><span data-hud="level" class="text-ink">1</span>
              </div>
              <div class="bg-canvas/70 px-2 py-1 border border-line">
                <span class="text-muted">BEST </span><span data-hud="best" class="text-ink">—</span>
              </div>
              <div class="bg-canvas/70 px-2 py-1 border border-line">
                <span class="text-muted">✨ </span><span data-hud="stardust" class="text-ink">0</span>
              </div>
              <div class="bg-canvas/70 px-2 py-1 border border-line flex items-center gap-1.5">
                <span class="text-muted">⛽</span>
                <div class="w-9 h-1.5 bg-line/50">
                  <div data-hud="fuel-bar" class="h-full bg-signal" style="width:100%"></div>
                </div>
                <span data-hud="fuel" class="text-ink">100</span>
              </div>
            </div>
            <div class="flex gap-1.5 sm:gap-3">
              <div class="bg-canvas/70 px-2 py-1 border border-line">
                <span class="text-muted">ALT </span><span data-hud="altitude" class="text-ink">—</span>
              </div>
              <div class="bg-canvas/70 px-2 py-1 border border-line">
                <span class="text-muted">SPD </span><span data-hud="speed" class="text-ink">0</span>
              </div>
            </div>
          </div>

          <!-- Touch controls (mobile) — corner-anchored overlay directly on
               the canvas, not a separate row below it. This is the standard
               two-thumb mobile layout: left thumb rests over the rotate
               pair (opposing actions, so adjacent buttons make sense),
               right thumb owns thrust. Anchoring to the canvas itself means
               there's zero extra scroll distance between "canvas visible"
               and "controls reachable" — the #1 mobile complaint this
               rework addresses. `pointer-events-none` on the wrapper +
               `pointer-events-auto` on each cluster keeps the dead space
               between the clusters from swallowing taps meant for the
               canvas/HUD above it. The 4th "ability" button (§6.2) is
               hidden by default via the `hidden` class; main.ts toggles it
               when the player owns >=1 active-ability upgrade. -->
          <div class="touch-controls absolute inset-x-0 bottom-0 items-end justify-between gap-3 p-3 sm:p-4 select-none pointer-events-none">
            <div class="flex gap-2 pointer-events-auto">
              <button data-touch="left" class="touch-btn bg-canvas/70 border border-line text-ink font-display text-2xl" aria-label="Rotate left">⟲</button>
              <button data-touch="right" class="touch-btn bg-canvas/70 border border-line text-ink font-display text-2xl" aria-label="Rotate right">⟳</button>
            </div>
            <div class="flex flex-col items-center gap-2 pointer-events-auto">
              <button data-touch="ability" class="touch-btn touch-btn-ability hidden bg-canvas/70 border border-line text-ink font-display text-xl" aria-label="Use ability">◈</button>
              <button data-touch="thrust" class="touch-btn touch-btn-thrust bg-canvas/70 border border-line badge-signal font-display text-2xl" aria-label="Thrust">▲</button>
            </div>
          </div>

          <!-- Overlay (start / upgrade / crash / shop screens).
               NOTE: content centers via m-auto on the child, NOT
               items-center on the flex parent — flex-centering clips the
               top of any content taller than the canvas and makes it
               unreachable by scroll (that's what truncated the shop). -->
          <div data-overlay class="absolute inset-0 bg-canvas/92 backdrop-blur-sm flex p-4 sm:p-6 overflow-y-auto">
            <div data-overlay-content class="w-full m-auto"></div>
          </div>
        </div>
      </div>

      <!-- Sound settings: independent mute + volume per channel -->
      <div class="flex flex-wrap items-center justify-between gap-x-6 gap-y-2 mt-3 font-mono text-xs text-muted">
        <p>←/→ or A/D rotate · ↑ / W / Space thrust</p>
        <div class="flex items-center gap-5">
          <label class="flex items-center gap-2 cursor-pointer">
            <button type="button" data-pause aria-label="Pause" title="Pause (Esc/P)" class="cursor-pointer hover:opacity-80 transition-opacity">⏸</button>
            <button data-mute-sfx type="button" aria-label="Toggle sound effects" class="cursor-pointer hover:opacity-80 transition-opacity">🔊</button>
            <input data-vol-sfx type="range" min="0" max="100" value="90" class="lander-vol" aria-label="Sound effects volume" />
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <button data-mute-music type="button" aria-label="Toggle music" class="cursor-pointer hover:opacity-80 transition-opacity">🎵</button>
            <input data-vol-music type="range" min="0" max="100" value="75" class="lander-vol" aria-label="Music volume" />
          </label>
        </div>
      </div>

      <!-- Mobile-only: the page header relocated below the game so the
           canvas is first. Collapsed by default. -->
      <details class="sm:hidden mt-4">
        <summary class="font-display font-semibold cursor-pointer select-none">
          <span class="badge mr-2">play</span>About Moon Lander
        </summary>
        <p class="text-muted mt-2 text-sm">
          Land gently on the pad. Endless levels, each harder than the last — pick an
          upgrade after every landing, but every boon has a cost. Three difficulty
          modes. Built with canvas + Web Audio, no libraries.
        </p>
      </details>
    </div>
  </div>
</Layout>

<style>
  /* On phones, break the game out of the page gutters so the canvas gets
     every available pixel — the tile's side borders/rounding go with it. */
  @media (max-width: 720px) {
    .game-bleed {
      margin-left: -1.5rem;
      margin-right: -1.5rem;
    }
    .game-bleed > .tile {
      border-left: none;
      border-right: none;
      border-radius: 0;
    }
  }

  .lander-vol {
    width: 110px;
    accent-color: var(--color-accent);
    cursor: pointer;
  }

  /* Matches the sticky .glass-nav height + a little breathing room, so
     #lander-root.scrollIntoView({block:'start'}) (main.ts's setOverlay,
     called whenever a crash/level-complete/shop overlay opens) lands the
     canvas just below the nav instead of partly hidden behind it. */
  #lander-root {
    scroll-margin-top: 4.5rem;
  }

  /* Touch hygiene: no double-tap zoom, no text selection, no gray tap
     flashes on the game surface or the thumb buttons. */
  #lander-root canvas,
  #lander-root [data-touch] {
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  #lander-root {
    -webkit-tap-highlight-color: transparent;
  }

  /* Corner-anchored touch controls — sized/shaped here; color comes from
     the same bg-canvas/70 + border-line utilities the HUD chips use, so
     they read as one visual system. Brighten/scale on press for immediate
     feedback (main.ts's bindTouch toggles .is-pressed; real devices don't
     reliably show :active once touch-action:none + preventDefault are in
     play). env(safe-area-inset-bottom) keeps buttons clear of the
     home-indicator bar on notched phones. */
  .touch-btn {
    width: 3.25rem;
    height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    cursor: pointer;
    transition: transform 0.08s ease, border-color 0.08s ease;
  }
  .touch-btn-thrust {
    width: 4.5rem;
    height: 4.5rem;
  }
  .touch-btn-ability {
    width: 2.75rem;
    height: 2.75rem;
    font-size: 1rem;
  }
  .touch-btn.is-pressed {
    border-color: var(--color-accent);
    transform: scale(0.92);
  }
  .touch-controls {
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
  }
</style>

<script>
  import { initLanderGame } from '../scripts/lander-game';

  let cleanup: (() => void) | null = null;

  // Page-scoped viewport lock: disable pinch/double-tap zoom while on the
  // game page (accidental zooms during play), restored on navigation away.
  const VIEWPORT_DEFAULT = 'width=device-width, initial-scale=1';
  const VIEWPORT_GAME = 'width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no';
  function setViewport(content: string) {
    document.querySelector('meta[name="viewport"]')?.setAttribute('content', content);
  }

  function boot() {
    const root = document.getElementById('lander-root');
    if (!root) return;
    setViewport(VIEWPORT_GAME);
    cleanup?.();
    cleanup = initLanderGame(root);
  }

  document.addEventListener('astro:page-load', boot);
  document.addEventListener('astro:before-swap', () => {
    setViewport(VIEWPORT_DEFAULT);
    cleanup?.();
    cleanup = null;
  });
</script>

---
// Live "what's happening outside" widget: weather, sun arc, moon phase,
// and the next visible ISS pass — fetched/computed client-side, no API
// keys. Defaults to Breckenridge, TX; visitors can opt in to their own
// location via the browser Geolocation API (button-gated, graceful
// fallback).
//
// v7 redesign: structured like a proper instrument panel — one header
// row, one current-conditions row with a hairline-divided stat strip,
// then two matching sky charts (sun + ISS). The ISS chart is now a
// static plot of the actual predicted pass (trajectory height scaled to
// peak elevation) instead of the old decorative bouncing dot, which
// read as noise rather than information.
---

<div class="outside-panel reveal" id="outside-widget">
  <!-- Header -->
  <div class="flex items-center justify-between flex-wrap gap-3">
    <div class="flex items-center gap-2.5">
      <span class="w-1.5 h-1.5 bg-signal live-pulse shrink-0" aria-hidden="true"></span>
      <span class="badge">outside</span>
      <span class="font-display text-sm font-semibold text-ink" data-field="location-label">Breckenridge, TX</span>
    </div>
    <button
      id="use-location-btn"
      type="button"
      class="badge border border-line px-2.5 py-1.5 hover:text-ink hover:border-accent transition-colors cursor-pointer"
    >
      use my location
    </button>
  </div>
  <p class="text-xs text-muted mt-2" data-field="location-status" hidden></p>

  <!-- Current conditions -->
  <div class="mt-5 grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-x-10 gap-y-5 items-center">
    <div class="flex items-center gap-4 min-w-[180px]">
      <p class="font-display text-5xl font-semibold tracking-tight tabular-nums leading-none" data-field="weather-temp">—</p>
      <div>
        <p class="text-sm text-ink" data-field="weather-desc">Loading…</p>
        <p class="text-xs text-muted mt-1 font-mono">
          feels <span class="text-ink" data-field="weather-feelslike">—</span>
          · H <span class="text-ink" data-field="weather-hi">—</span>
          · L <span class="text-ink" data-field="weather-lo">—</span>
        </p>
      </div>
    </div>

    <div class="grid grid-cols-3 sm:grid-cols-6 gap-px bg-line border border-line">
      <div class="bg-surface px-3 py-2.5">
        <p class="badge">humidity</p>
        <p class="text-sm font-mono mt-1 tabular-nums" data-field="weather-humidity">—</p>
      </div>
      <div class="bg-surface px-3 py-2.5">
        <p class="badge">wind</p>
        <p class="text-sm font-mono mt-1 tabular-nums" data-field="weather-wind">—</p>
      </div>
      <div class="bg-surface px-3 py-2.5">
        <p class="badge">uv index</p>
        <p class="text-sm font-mono mt-1 tabular-nums" data-field="weather-uv">—</p>
      </div>
      <div class="bg-surface px-3 py-2.5">
        <p class="badge">rain</p>
        <p class="text-sm font-mono mt-1 tabular-nums" data-field="weather-precip">—</p>
      </div>
      <div class="bg-surface px-3 py-2.5">
        <p class="badge">clouds</p>
        <p class="text-sm font-mono mt-1 tabular-nums" data-field="weather-cloud">—</p>
      </div>
      <div class="bg-surface px-3 py-2.5">
        <p class="badge">moon</p>
        <p class="text-sm font-mono mt-1 tabular-nums" data-field="moon-phase" data-moon-title>—</p>
      </div>
    </div>
  </div>

  <!-- Sky charts: sun + next ISS pass, same horizon geometry side by side -->
  <div class="mt-6 pt-5 border-t border-line grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-7">
    <div>
      <div class="flex items-baseline justify-between">
        <p class="badge">sun</p>
        <p class="text-xs font-mono text-muted">sets <span class="text-ink" data-field="sunset-time">—</span></p>
      </div>
      <svg class="sun-arc mt-2 w-full h-auto" viewBox="0 0 300 140" aria-hidden="true">
        <line x1="20" y1="112" x2="280" y2="112" stroke="var(--color-line)" stroke-width="1.5" />
        <path d="M 54 112 A 96 96 0 0 1 246 112" fill="none" stroke="var(--color-line)" stroke-width="1.5" stroke-dasharray="2 5" />
        <path data-field="sun-golden-rise" fill="none" stroke="rgba(var(--color-accent-rgb), 0.55)" stroke-width="4" stroke-linecap="round" />
        <path data-field="sun-golden-set" fill="none" stroke="rgba(var(--color-accent-rgb), 0.55)" stroke-width="4" stroke-linecap="round" />
        <circle data-field="sun-dot" cx="54" cy="112" r="6" fill="var(--color-accent-mid)" />
        <text x="54" y="126" font-size="9" fill="var(--color-muted)" font-family="var(--font-mono)" text-anchor="middle">sunrise</text>
        <text data-field="sunrise-time-label" x="54" y="137" font-size="9" fill="var(--color-ink)" font-family="var(--font-mono)" text-anchor="middle">—</text>
        <text x="246" y="126" font-size="9" fill="var(--color-muted)" font-family="var(--font-mono)" text-anchor="middle">sunset</text>
        <text data-field="sunset-time-label" x="246" y="137" font-size="9" fill="var(--color-ink)" font-family="var(--font-mono)" text-anchor="middle">—</text>
      </svg>
      <p class="text-xs text-muted mt-1.5" data-field="sunset-quality">Loading forecast…</p>
    </div>

    <div>
      <div class="flex items-baseline justify-between">
        <p class="badge">next ISS pass</p>
        <p class="text-xs font-mono text-ink" data-field="iss-when">—</p>
      </div>
      <svg class="iss-arc mt-2 w-full h-auto" viewBox="0 0 300 140" aria-hidden="true">
        <line x1="20" y1="112" x2="280" y2="112" stroke="var(--color-line)" stroke-width="1.5" />
        <path d="M 54 112 A 96 96 0 0 1 246 112" fill="none" stroke="var(--color-line)" stroke-width="1.5" stroke-dasharray="2 5" />
        <path data-field="iss-path" fill="none" stroke="var(--color-signal)" stroke-width="2" stroke-linecap="round" />
        <circle data-field="iss-apex-dot" cx="150" cy="16" r="3.5" fill="var(--color-signal)" style="display:none" />
        <text data-field="iss-apex-label" x="150" y="10" font-size="9" fill="var(--color-muted)" font-family="var(--font-mono)" text-anchor="middle"></text>
        <circle cx="54" cy="112" r="2.5" fill="var(--color-muted)" />
        <circle cx="246" cy="112" r="2.5" fill="var(--color-muted)" />
        <text x="54" y="126" font-size="9" fill="var(--color-muted)" font-family="var(--font-mono)" text-anchor="middle">rises</text>
        <text data-field="iss-rise-label" x="54" y="137" font-size="9" fill="var(--color-ink)" font-family="var(--font-mono)" text-anchor="middle">—</text>
        <text x="246" y="126" font-size="9" fill="var(--color-muted)" font-family="var(--font-mono)" text-anchor="middle">sets</text>
        <text data-field="iss-set-label" x="246" y="137" font-size="9" fill="var(--color-ink)" font-family="var(--font-mono)" text-anchor="middle">—</text>
      </svg>
      <p class="text-xs text-muted mt-1.5" data-field="iss-pass-summary">Loading pass predictions…</p>
    </div>
  </div>
</div>

<script>
  const BRECKENRIDGE = { lat: 32.7557, lon: -98.9023, label: 'Breckenridge, TX' };
  let current = { ...BRECKENRIDGE };

  // Shared geometry for both horizon-to-horizon sky charts.
  const ARC = { cx: 150, cy: 112, r: 96 };

  function arcPoint(cx: number, cy: number, r: number, progress: number) {
    const p = Math.max(0, Math.min(1, progress));
    const angle = Math.PI * (1 - p); // PI at progress=0 (left horizon) -> 0 at progress=1 (right horizon)
    return { x: cx + r * Math.cos(angle), y: cy - r * Math.sin(angle) };
  }

  function arcSegmentPath(cx: number, cy: number, r: number, pFrom: number, pTo: number) {
    const a = arcPoint(cx, cy, r, pFrom);
    const b = arcPoint(cx, cy, r, pTo);
    return `M ${a.x.toFixed(1)} ${a.y.toFixed(1)} A ${r} ${r} 0 0 1 ${b.x.toFixed(1)} ${b.y.toFixed(1)}`;
  }

  function setField(name: string, value: string) {
    document.querySelectorAll(`[data-field="${name}"]`).forEach((el) => {
      el.textContent = value;
    });
  }

  function setStatus(msg: string) {
    const el = document.querySelector('[data-field="location-status"]') as HTMLElement | null;
    if (!el) return;
    if (!msg) {
      el.hidden = true;
      el.textContent = '';
    } else {
      el.hidden = false;
      el.textContent = msg;
    }
  }

  const WEATHER_CODES: Record<number, string> = {
    0: 'Clear sky', 1: 'Mostly clear', 2: 'Partly cloudy', 3: 'Overcast',
    45: 'Fog', 48: 'Freezing fog',
    51: 'Light drizzle', 53: 'Drizzle', 55: 'Heavy drizzle',
    61: 'Light rain', 63: 'Rain', 65: 'Heavy rain',
    71: 'Light snow', 73: 'Snow', 75: 'Heavy snow',
    80: 'Rain showers', 81: 'Rain showers', 82: 'Violent showers',
    95: 'Thunderstorm', 96: 'Thunderstorm w/ hail', 99: 'Severe thunderstorm',
  };

  const COMPASS = ['N', 'NNE', 'NE', 'ENE', 'E', 'ESE', 'SE', 'SSE', 'S', 'SSW', 'SW', 'WSW', 'W', 'WNW', 'NW', 'NNW'];
  function compassFromDegrees(deg: number): string {
    return COMPASS[Math.round(deg / 22.5) % 16];
  }

  function sunsetQuality(cloudPct: number): string {
    if (cloudPct < 15) return 'Clear — simple gold, minimal color';
    if (cloudPct < 45) return 'Vibrant — good chance of color';
    if (cloudPct < 70) return 'Painted — clouds catching light';
    if (cloudPct < 90) return 'Muted — heavy cloud, soft glow at best';
    return 'Socked in — sunset likely hidden';
  }

  // --- Sun chart: position updates on a slow interval (data itself only
  // needs to be fetched once per location — sunrise/sunset don't move
  // minute to minute, only the sun's rendered position along the arc does). ---
  let sunTimes: { sunrise: Date; sunset: Date } | null = null;
  let sunArcInterval: ReturnType<typeof setInterval> | null = null;

  function updateSunArc() {
    if (!sunTimes) return;
    const svg = document.querySelector('.sun-arc');
    if (!svg) return;
    const { sunrise, sunset } = sunTimes;
    const total = sunset.getTime() - sunrise.getTime();
    const progress = (Date.now() - sunrise.getTime()) / total;
    const isDaytime = progress >= 0 && progress <= 1;

    const dot = svg.querySelector('[data-field="sun-dot"]') as SVGElement | null;
    if (dot) {
      if (isDaytime) {
        const p = arcPoint(ARC.cx, ARC.cy, ARC.r, progress);
        dot.setAttribute('cx', p.x.toFixed(1));
        dot.setAttribute('cy', p.y.toFixed(1));
        dot.style.display = '';
      } else {
        dot.style.display = 'none';
      }
    }

    const goldenFrac = Math.min(0.18, 3600000 / total);
    svg.querySelector('[data-field="sun-golden-rise"]')?.setAttribute('d', arcSegmentPath(ARC.cx, ARC.cy, ARC.r, 0, goldenFrac));
    svg.querySelector('[data-field="sun-golden-set"]')?.setAttribute('d', arcSegmentPath(ARC.cx, ARC.cy, ARC.r, 1 - goldenFrac, 1));
  }

  function fmtTime(d: Date): string {
    return d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
  }

  async function loadWeather(lat: number, lon: number) {
    try {
      const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}` +
        `&current=temperature_2m,apparent_temperature,relative_humidity_2m,weather_code,cloud_cover,wind_speed_10m,wind_direction_10m` +
        `&hourly=cloud_cover` +
        `&daily=sunrise,sunset,temperature_2m_max,temperature_2m_min,uv_index_max,precipitation_probability_max` +
        `&temperature_unit=fahrenheit&wind_speed_unit=mph&timezone=auto&forecast_days=1`;
      const res = await fetch(url);
      const data = await res.json();
      const cur = data.current;
      const daily = data.daily;

      setField('weather-temp', `${Math.round(cur.temperature_2m)}°`);
      setField('weather-desc', WEATHER_CODES[cur.weather_code] ?? 'Weather unavailable');
      setField('weather-feelslike', `${Math.round(cur.apparent_temperature)}°`);
      setField('weather-hi', `${Math.round(daily.temperature_2m_max[0])}°`);
      setField('weather-lo', `${Math.round(daily.temperature_2m_min[0])}°`);
      setField('weather-humidity', `${Math.round(cur.relative_humidity_2m)}%`);
      setField('weather-wind', `${Math.round(cur.wind_speed_10m)} ${compassFromDegrees(cur.wind_direction_10m)}`);
      setField('weather-uv', daily.uv_index_max?.[0] != null ? `${Math.round(daily.uv_index_max[0] * 10) / 10}` : '—');
      setField('weather-precip', `${Math.round(daily.precipitation_probability_max?.[0] ?? 0)}%`);
      setField('weather-cloud', `${Math.round(cur.cloud_cover)}%`);

      const sunriseDate = new Date(daily.sunrise[0]);
      const sunsetDate = new Date(daily.sunset[0]);
      setField('sunset-time', fmtTime(sunsetDate));
      setField('sunrise-time-label', fmtTime(sunriseDate));
      setField('sunset-time-label', fmtTime(sunsetDate));

      const hourlyTimes: string[] = data.hourly.time;
      const hourlyClouds: number[] = data.hourly.cloud_cover;
      let closestIdx = 0;
      let closestDiff = Infinity;
      hourlyTimes.forEach((t, i) => {
        const diff = Math.abs(new Date(t).getTime() - sunsetDate.getTime());
        if (diff < closestDiff) {
          closestDiff = diff;
          closestIdx = i;
        }
      });
      const cloudAtSunset = hourlyClouds[closestIdx] ?? cur.cloud_cover;
      setField('sunset-quality', sunsetQuality(cloudAtSunset));

      sunTimes = { sunrise: sunriseDate, sunset: sunsetDate };
      updateSunArc();
      if (!sunArcInterval) sunArcInterval = setInterval(updateSunArc, 120000);
    } catch (e) {
      setField('weather-desc', "Couldn't load weather");
      ['weather-temp', 'weather-feelslike', 'weather-hi', 'weather-lo', 'weather-humidity',
        'weather-wind', 'weather-uv', 'weather-precip', 'weather-cloud'].forEach((f) => setField(f, '—'));
      setField('sunset-quality', "Couldn't load forecast");
    }
  }

  function moonPhase(date: Date) {
    const synodic = 29.53058867;
    const knownNewMoon = Date.UTC(2000, 0, 6, 18, 14, 0);
    const daysSince = (date.getTime() - knownNewMoon) / 86400000;
    let phase = (daysSince % synodic) / synodic;
    if (phase < 0) phase += 1;
    return phase;
  }

  function loadMoon() {
    // Moon phase is the same everywhere on Earth (give or take a day near
    // the terminator), so this doesn't depend on location.
    const phase = moonPhase(new Date());
    const illum = Math.round((1 - Math.cos(2 * Math.PI * phase)) / 2 * 100);

    let name = 'New Moon';
    let emoji = '🌑';
    if (phase < 0.033 || phase >= 0.967) { name = 'New Moon'; emoji = '🌑'; }
    else if (phase < 0.216) { name = 'Waxing Crescent'; emoji = '🌒'; }
    else if (phase < 0.284) { name = 'First Quarter'; emoji = '🌓'; }
    else if (phase < 0.466) { name = 'Waxing Gibbous'; emoji = '🌔'; }
    else if (phase < 0.534) { name = 'Full Moon'; emoji = '🌕'; }
    else if (phase < 0.716) { name = 'Waning Gibbous'; emoji = '🌖'; }
    else if (phase < 0.784) { name = 'Last Quarter'; emoji = '🌗'; }
    else { name = 'Waning Crescent'; emoji = '🌘'; }

    setField('moon-phase', `${emoji} ${illum}%`);
    const cell = document.querySelector('[data-moon-title]') as HTMLElement | null;
    if (cell) cell.title = `${name} — ${illum}% illuminated`;
  }

  // --- ISS next-pass prediction (Pollux Labs — free, no key, CORS-enabled,
  // SGP4/Skyfield against fresh Celestrak TLEs; superseded Open Notify,
  // which was retired). The chart is a static plot of the real predicted
  // pass: trajectory height is scaled to the pass's peak elevation
  // (90° = zenith = top of the reference dome). ---
  interface IssPass {
    rise: { time: string; azimuth_deg: number; compass: string };
    culmination: { time: string; elevation_deg: number };
    set: { time: string; azimuth_deg: number; compass: string };
    duration_sec: number;
  }

  function formatPassWhen(d: Date): string {
    const now = new Date();
    const time = fmtTime(d);
    if (d.toDateString() === now.toDateString()) return `Today, ${time}`;
    const tomorrow = new Date(now);
    tomorrow.setDate(now.getDate() + 1);
    if (d.toDateString() === tomorrow.toDateString()) return `Tomorrow, ${time}`;
    return `${d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}, ${time}`;
  }

  function formatDuration(sec: number): string {
    const m = Math.floor(sec / 60);
    const s = Math.round(sec % 60);
    return m > 0 ? `${m}m ${s}s` : `${s}s`;
  }

  function renderIssPass(pass: IssPass | null) {
    const svg = document.querySelector('.iss-arc');
    if (!svg) return;
    const path = svg.querySelector('[data-field="iss-path"]');
    const dot = svg.querySelector('[data-field="iss-apex-dot"]') as SVGElement | null;
    const apexLabel = svg.querySelector('[data-field="iss-apex-label"]');

    if (!pass) {
      path?.removeAttribute('d');
      if (dot) dot.style.display = 'none';
      if (apexLabel) apexLabel.textContent = '';
      setField('iss-rise-label', '—');
      setField('iss-set-label', '—');
      return;
    }

    // Quadratic curve horizon-to-horizon; apex height maps peak elevation
    // onto the same scale as the dashed reference dome (90° = dome top).
    const elev = Math.min(90, Math.max(0, pass.culmination.elevation_deg));
    const apexY = ARC.cy - (elev / 90) * ARC.r;
    const ctrlY = 2 * apexY - ARC.cy;
    path?.setAttribute('d', `M 54 ${ARC.cy} Q ${ARC.cx} ${ctrlY.toFixed(1)} 246 ${ARC.cy}`);
    if (dot) {
      dot.setAttribute('cx', String(ARC.cx));
      dot.setAttribute('cy', apexY.toFixed(1));
      dot.style.display = '';
    }
    if (apexLabel) {
      apexLabel.setAttribute('y', Math.max(9, apexY - 8).toFixed(1));
      apexLabel.textContent = `${Math.round(pass.culmination.elevation_deg)}° max`;
    }
    setField('iss-rise-label', pass.rise.compass);
    setField('iss-set-label', pass.set.compass);
  }

  async function loadIssPass(lat: number, lon: number) {
    const svg = document.querySelector('.iss-arc');
    try {
      const url = `https://iss-api.polluxlabs.io/iss-pass?lat=${lat}&lon=${lon}&visible_only=true&n=3&days_ahead=10&min_elevation=10`;
      const res = await fetch(url);
      const data = await res.json();
      const passes: IssPass[] = data.passes ?? [];

      if (passes.length === 0) {
        setField('iss-when', '—');
        setField('iss-pass-summary', 'No visible passes in the next 10 days');
        renderIssPass(null);
        svg?.classList.add('opacity-40');
        return;
      }

      svg?.classList.remove('opacity-40');
      const nextPass = passes[0];
      const riseDate = new Date(nextPass.rise.time);
      setField('iss-when', formatPassWhen(riseDate));
      setField('iss-pass-summary',
        `Crosses ${nextPass.rise.compass} → ${nextPass.set.compass} · visible ${formatDuration(nextPass.duration_sec)}`);
      renderIssPass(nextPass);
    } catch (e) {
      setField('iss-when', '—');
      setField('iss-pass-summary', "Couldn't load ISS pass predictions");
      renderIssPass(null);
    }
  }

  async function reverseGeocodeLabel(lat: number, lon: number): Promise<string> {
    try {
      const res = await fetch(
        `https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${lat}&longitude=${lon}&localityLanguage=en`
      );
      const data = await res.json();
      const city = data.city || data.locality;
      const region = data.principalSubdivisionCode?.split('-')[1] || data.principalSubdivision;
      if (city && region) return `${city}, ${region}`;
      if (data.locality) return data.locality;
    } catch (e) {
      // fall through to coordinate label
    }
    return `${lat.toFixed(2)}, ${lon.toFixed(2)}`;
  }

  async function refreshFor(lat: number, lon: number, label: string) {
    setField('location-label', label);
    await Promise.all([loadWeather(lat, lon), loadIssPass(lat, lon)]);
  }

  function useMyLocation() {
    const btn = document.getElementById('use-location-btn');
    if (!('geolocation' in navigator)) {
      setStatus("Your browser doesn't support geolocation — showing Breckenridge, TX.");
      return;
    }
    setStatus('Requesting your location…');
    if (btn) (btn as HTMLButtonElement).disabled = true;

    navigator.geolocation.getCurrentPosition(
      async (pos) => {
        const { latitude, longitude } = pos.coords;
        current = { lat: latitude, lon: longitude, label: 'your location' };
        setStatus('Got it — updating…');
        const label = await reverseGeocodeLabel(latitude, longitude);
        await refreshFor(latitude, longitude, label);
        setStatus('');
        if (btn) (btn as HTMLButtonElement).disabled = false;
      },
      () => {
        // Declined or failed — graceful fallback, stay on Breckenridge data.
        setStatus("Couldn't get your location — showing Breckenridge, TX instead.");
        if (btn) (btn as HTMLButtonElement).disabled = false;
      },
      { timeout: 8000 }
    );
  }

  function initOutsideWidget() {
    current = { ...BRECKENRIDGE };
    setField('location-label', BRECKENRIDGE.label);
    setStatus('');
    loadWeather(BRECKENRIDGE.lat, BRECKENRIDGE.lon);
    loadMoon();
    loadIssPass(BRECKENRIDGE.lat, BRECKENRIDGE.lon);

    const btn = document.getElementById('use-location-btn');
    btn?.addEventListener('click', useMyLocation);
  }

  document.addEventListener('astro:page-load', initOutsideWidget);
  document.addEventListener('astro:before-swap', () => {
    if (sunArcInterval) {
      clearInterval(sunArcInterval);
      sunArcInterval = null;
    }
  }, { once: true });
</script>
